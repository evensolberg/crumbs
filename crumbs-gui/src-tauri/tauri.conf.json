{
  "productName": "crumbs",
  "version": "0.16.3",
  "identifier": "sh.evensolberg.crumbs-gui",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "crumbs",
        "width": 1200,
        "height": 750,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/Icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
